{
  "name": "tikeffect",
  "version": "1.0.3",
  "main": "electron/main.js",
  "scripts": {
    "predev": "npm rebuild better-sqlite3",
    "dev": "chcp 65001>nul & nodemon --legacy-watch index.js",
    "prestart": "npm rebuild better-sqlite3",
    "start": "chcp 65001>nul & node index.js",
    "prebackend:dev": "npm rebuild better-sqlite3",
    "backend:dev": "chcp 65001>nul & nodemon --legacy-watch backend/index.js",
    "prebackend:start": "npm rebuild better-sqlite3",
    "backend:start": "chcp 65001>nul & node backend/index.js",
    "generate:windows-launchers": "chcp 65001>nul & node scripts/generate-windows-launchers.js",
    "rebuild:electron": "electron-rebuild -f better-sqlite3",
    "loader": "chcp 65001>nul & node loader-server/index.js",
    "preelectron": "powershell -ExecutionPolicy Bypass -File .\\scripts\\prepare-electron.ps1",
    "electron": "chcp 65001>nul & electron .",
    "preelectron:dev": "powershell -ExecutionPolicy Bypass -File .\\scripts\\prepare-electron.ps1",
    "electron:dev": "chcp 65001>nul & nodemon --legacy-watch --exec \"electron .\" backend/index.js electron/main.js",
    "build:windows": "electron-builder --win --x64 --config electron-builder.config.js",
    "publish:r2": "powershell -ExecutionPolicy Bypass -File .\\scripts\\publish-r2.ps1",
    "build:publish": "npm run build:windows && npm run publish:r2"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "electron-updater": "^6.6.2",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "socket.io": "^4.7.2",
    "tiktok-live-connector": "^2.1.1-beta1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.0.1"
  }
}
